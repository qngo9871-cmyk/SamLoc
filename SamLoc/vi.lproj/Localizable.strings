"onboarding.combos.title" = "Chặt Bài Trước";
"onboarding.combos.body" = "Đánh một lá, đôi, bộ ba, hoặc sảnh cùng chất lớn hơn bài trước — hoặc bỏ lượt. Tứ quý chặt được tất cả.";
"onboarding.special.title" = "Coi Chừng Bẫy";
"onboarding.special.body" = "Bài mở đầu hoàn hảo có thể thắng ngay (\"Tới Trắng\") — nhưng bạn không thể thắng bằng lá 2 lẻ. Chạm \"Luật Đầy Đủ\" bất cứ lúc nào để xem chi tiết.";
"onboarding.next" = "Tiếp";
