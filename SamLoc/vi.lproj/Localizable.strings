"rules.deal.title" = "Chia Bài";
"rules.deal.body" = "4 người chơi, mỗi người 10 lá. Thứ tự từ 3 (nhỏ nhất) đến Át, rồi đến 2 (\"heo\") là lá mạnh nhất. Ai có 3♠ được đánh trước.";
"rules.combos.title" = "Các Bộ Bài";
"rules.combos.body" = "Đánh một lá, đôi, bộ ba, hoặc sảnh cùng chất (từ 3 lá) lớn hơn bài trước đó — hoặc bỏ lượt. Tứ quý là bộ chặt tất cả, kể cả một lá 2 lẻ.";
"rules.instantwin.title" = "Tới Trắng";
"rules.instantwin.body" = "Nếu 10 lá bài đầu tiên của bạn tạo thành Sảnh Rồng, Tứ Quý 2, đồng màu, Ba Bộ Ba, hoặc Năm Đôi, bạn thắng ngay ván đó — trước khi ai đánh một lá nào.";
"rules.heo.title" = "Luật Lá 2 Lẻ";
"rules.heo.body" = "Bạn không thể thắng bằng cách đánh một lá 2 lẻ làm lá cuối cùng — hãy giữ nó để ghép đôi, bộ ba, hoặc sảnh.";
"rules.sam.title" = "Báo Sâm";
"rules.sam.body" = "Khi có bài mạnh và ngắn, hãy báo Sâm trước khi ra bài. Thắng ván sẽ được nhân đôi điểm — nhưng báo Sâm thất bại sẽ bị phạt gấp đôi.";
"rules.scoring.title" = "Tính Điểm";
"rules.scoring.body" = "Người thắng ván tính điểm từ số bài còn lại của những người khác. Lá 2 chưa đánh và tứ quý chưa đánh sẽ bị phạt thêm.";
